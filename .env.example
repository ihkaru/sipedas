APP_NAME=SIKENDIS
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://admin.dvlpid.my.id
APP_KEY=

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# Database (MySQL recommended for Production)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=sikendis
DB_USERNAME=root
DB_PASSWORD=

# Session & Cache (Redis is HIGHLY recommended for Worker Mode/Octane)
SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# Redis Configuration
# You can use individual variables or a single REDIS_URL (priority)
# REDIS_URL=redis://default:password@host:port/0
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Mail Configuration
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Octane & FrankenPHP (April 2026 Production Stack)
OCTANE_SERVER=frankenphp
OCTANE_MAX_REQUESTS=1000
FRANKENPHP_MAX_REQUESTS=1000

# Security (Cloudflare / Coolify / Traefik)
# Comma separated list of trusted proxies or '*'
# TRUSTED_PROXIES="*"

# Third Party Integrations
GOOGLE_APPLICATION_NAME=SIKENDIS
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT=https://admin.dvlpid.my.id/login/google/callback
GOOGLE_DEVELOPER_KEY=

FONNTE_TOKEN=

# Vite
VITE_APP_NAME="${APP_NAME}"
